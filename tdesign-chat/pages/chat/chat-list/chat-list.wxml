<t-navbar class="demo-navbar" title="ChatList" leftArrow />
<view class="demo">
  <!-- Set chatSender value via isActive to avoid textarea being obscured on iOS -->
  <t-tabs space-evenly="{{false}}" swipeable="{{false}}" value="{{value}}" bind:change="onTabsChange">
    <t-tab-panel label="{{i18n.pages.chatList.tabs.basic}}" value="{{0}}">
      <base />
    </t-tab-panel>
    <t-tab-panel label="{{i18n.pages.chatList.tabs.composed}}" value="{{1}}">
      <hook-component isActive="{{ value === 1}}" />
    </t-tab-panel>
    <t-tab-panel label="{{i18n.pages.chatList.tabs.custom}}" value="{{2}}">
      <custom isActive="{{ value === 2}}" />
    </t-tab-panel>
    <!-- Not included in this iteration -->
    <!-- <t-tab-panel label="{{i18n.pages.chatList.tabs.codeAssistant}}" value="{{3}}">
      <codedemo />
    </t-tab-panel> -->
    <t-tab-panel label="{{i18n.pages.chatList.tabs.contentAssistant}}" value="{{4}}">
      <docs isActive="{{ value === 4}}" />
    </t-tab-panel>
    <t-tab-panel label="{{i18n.pages.chatList.tabs.imageGen}}" value="{{5}}">
      <imagedemo isActive="{{ value === 5}}" />
    </t-tab-panel>
    <t-tab-panel label="{{i18n.pages.chatList.tabs.taskPlan}}" value="{{6}}">
      <agent isActive="{{ value === 6}}" />
    </t-tab-panel>
  </t-tabs>
</view>
